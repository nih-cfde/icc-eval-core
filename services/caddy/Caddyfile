# Local (HTTP)
:80 {
	handle_path /static/* {
		root * /opt/static
		file_server
	}
	handle {
		reverse_proxy backend:8000
	}
}

# Production (HTTPS + automatic certs)
{$DOMAIN} {
	@backend_paths {
		path /api/* /admin/* /api-auth/* /accounts/*
	}
	handle_path /static/* {
		root * /opt/static
		file_server
	}
	handle @backend_paths {
		reverse_proxy backend:8000
	}

	# old handler for proxying to netlify
	# handle {
	# 	reverse_proxy https://cfde-eval.netlify.app {
	# 		header_up Host cfde-eval.netlify.app
	# 	}
	# }

	# serve frontend static files for all other paths
	handle {
		root * /opt/frontend
		file_server
		try_files {path} /index.html
	}
}
